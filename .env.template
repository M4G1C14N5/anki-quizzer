# Anki Quizzer — Environment Variables
# Copy to .env and fill in the values

# Port the server listens on
PORT=4318

# AnkiConnect URL
# Inside the same Docker network: http://anki-desktop:8765
# Across Coolify projects (different compose networks): http://<container-ip>:8764
# Local dev / host machine: http://192.168.192.119:8764
ANKI_URL=http://anki-desktop:8765

# Optional: directory for quiz history (last-results.json, history.jsonl)
# DATA_DIR=./data

# MiniMax (OpenAI-compatible) for session + cluster quiz generation
# Get a key: https://platform.minimax.io/user-center/basic-information/interface-key
# LLM_API_KEY is set in Coolify, NOT committed.
LLM_BASE_URL=https://api.minimax.io/v1
LLM_MODEL=MiniMax-M3
# LLM_CACHE_DIR=./data/llm-cache
# LLM_TIMEOUT_MS=90000
